APP_ENV=dev
CORS_ORIGINS=["http://localhost:5173"]
ANOMALIES_CSV_PATH=backend/data/Synthetic Accounting Financial Dataset.csv

# azure | ollama
LLM_PROVIDER=azure

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional: set to require `x-api-key` on non-health routes
API_KEY=

# Optional RBAC keys map (takes precedence over API_KEY), JSON format:
# API_KEYS={"auditor-key":"auditor","admin-key":"admin"}
API_KEYS={}

# Optional risk score overrides, JSON format:
# RISK_SCORE_BY_ACCOUNT={"4000":0.9,"5000":0.7}
# RISK_SCORE_BY_CATEGORY={"payroll":0.95,"travel":0.65}
RISK_SCORE_BY_ACCOUNT={}
RISK_SCORE_BY_CATEGORY={}

# Risk level cutoffs for score-to-level mapping
RISK_LEVEL_HIGH_CUTOFF=0.85
RISK_LEVEL_MEDIUM_CUTOFF=0.60
